{
  "name": "n8n-fpllefia",
  "dockerComposeFile": "docker-compose.yml",
  "service": "n8n",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "forwardPorts": [5678],
  "portsAttributes": {
    "5678": {
      "label": "n8n",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "echo 'Codespace listo. Abre la pestaña Ports y entra a 5678.'"
}
